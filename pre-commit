#!/usr/bin/env bash
# SmartScan pre-commit hook
# Применяет профиль fast ко всем изменённым .sol и .go файлам перед коммитом.
# Установка: chmod +x .git/hooks/pre-commit

set -euo pipefail

SMARTSCAN="python3 smartScan.py"
PROFILE="fast"
EXIT_CODE=0

# Получаем список изменённых файлов из индекса
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(sol|go)$' || true)

if [ -z "$CHANGED_FILES" ]; then
    echo "[SmartScan] Нет изменённых .sol или .go файлов — проверка пропущена."
    exit 0
fi

echo "[SmartScan] Запуск анализа (профиль: ${PROFILE})..."
echo "──────────────────────────────────────────"

for FILE in $CHANGED_FILES; do
    if [ ! -f "$FILE" ]; then
        continue
    fi

    echo "[SmartScan] Проверка: $FILE"
    REPORT=$(mktemp /tmp/smartscan_XXXXXX.json)

    if ! $SMARTSCAN "$FILE" --profile "$PROFILE" --output "$REPORT" 2>&1; then
        echo "[SmartScan] Ошибка при анализе файла: $FILE"
        rm -f "$REPORT"
        EXIT_CODE=1
        continue
    fi

    # Проверяем наличие критических проблем в итоговом JSON
    CRITICAL=$(python3 - <<EOF
import json, sys
try:
    with open("$REPORT") as f:
        data = json.load(f)
    print(data.get("summary", {}).get("critical", 0))
except Exception:
    print(0)
EOF
)

    rm -f "$REPORT"

    if [ "${CRITICAL}" -gt 0 ]; then
        echo "[SmartScan] Найдено критических проблем: ${CRITICAL} — в файле $FILE"
        EXIT_CODE=1
    else
        echo "[SmartScan] Проблем не обнаружено: $FILE"
    fi
done

echo "──────────────────────────────────────────"

if [ "$EXIT_CODE" -ne 0 ]; then
    echo "[SmartScan] Коммит заблокирован: обнаружены критические уязвимости."
    echo "            Исправьте проблемы и повторите попытку."
    exit 1
fi

echo "[SmartScan] Все проверки пройдены. Коммит разрешён."
exit 0
